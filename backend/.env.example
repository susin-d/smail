# ─── Database ───
MYSQL_ROOT_PASSWORD=changeme_root_password
MYSQL_DATABASE=smail
MYSQL_USER=smail_user
MYSQL_PASSWORD=changeme_db_password

# ─── JWT ───
JWT_SECRET=changeme_jwt_secret_key_at_least_32_chars
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440
# 0 for production, 1 only for local development.
SMAIL_DEV=0

# ─── Domain ───
PRIMARY_DOMAIN=mail.example.com
HOSTNAME=mail.example.com

# ─── Redis ───
REDIS_URL=redis://redis:6379/0

# ─── Mail ───
POSTMASTER_EMAIL=postmaster@example.com
MAX_MESSAGE_SIZE=10485760

# ─── DKIM ───
DKIM_SELECTOR=mail

# ─── API ───
API_HOST=0.0.0.0
API_PORT=8000
# Use exact frontend origins in production, comma-separated when needed.
CORS_ORIGINS=https://your-frontend.vercel.app

# ─── TLS ───
TLS_CERT_PATH=/etc/letsencrypt/live/mail.example.com/fullchain.pem
TLS_KEY_PATH=/etc/letsencrypt/live/mail.example.com/privkey.pem
